# ── Noto auth server configuration ───────────────────────────────────────────
# Copy to `.env` for local dev. In production, inject these as real env vars.

NODE_ENV=development
PORT=8787

# Public origin the browser uses. In dev this is the Vite server; in prod it is
# your real https origin (used for cookies, CSRF origin pinning, OAuth redirects).
APP_ORIGIN=http://localhost:5173

# ── Sessions ──────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate a strong value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
SESSION_COOKIE_NAME=noto_session
SESSION_TTL_DAYS=30

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file path (default works out of the box). To move to Postgres later,
# re-implement server/db.ts against DATABASE_URL.
DATABASE_PATH=./server/data/noto.sqlite
# DATABASE_URL=postgres://user:pass@host:5432/noto

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# The "Continue with Google" button stays inert until all three are set.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must equal GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/api/auth/google/callback
