# ── Noto auth server configuration ───────────────────────────────────────────
# Copy to `.env` for local dev. In production, inject these as real env vars.

NODE_ENV=development
PORT=8787

# Public origin the browser uses. In dev this is the Vite server; in prod it is
# your real https origin (used for cookies, CSRF origin pinning, OAuth redirects).
APP_ORIGIN=http://localhost:5173

# ── Sessions ──────────────────────────────────────────────────────────────────
# Recommended in production (required when running multiple instances). If unset,
# a strong secret is auto-generated and persisted in the database on first boot.
# Generate a strong value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
SESSION_COOKIE_NAME=noto_session
SESSION_TTL_DAYS=30

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file path (default works out of the box). To move to Postgres later,
# re-implement server/db.ts against DATABASE_URL.
DATABASE_PATH=./server/data/noto.sqlite
# DATABASE_URL=postgres://user:pass@host:5432/noto

# ── OpenAI (optional) ─────────────────────────────────────────────────────
# Powers the authenticated Noto AI features: chat, summarize, flashcards,
# find-links, and lecture transcription (gpt-4o-mini + gpt-4o-mini-transcribe).
# Left unset, the /api/ai/* routes return 503 and the UI shows "AI unavailable".
# The key is server-side only and is never exposed to the browser.
# Create one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── GitHub App connector (optional) ───────────────────────────────────────────
# Dump's GitHub source returns 503 until all five are set. Create a GitHub App at
# https://github.com/settings/apps with read-only contents/metadata/issues and a
# callback URL equal to GITHUB_REDIRECT_URI. Never commit real secrets.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8787/api/auth/github/callback

# ── Notion OAuth connector (optional — wired in a later phase) ─────────────────
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8787/api/auth/notion/callback
