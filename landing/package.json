{
  "name": "landing",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "fetch-embedding-model": "node scripts/fetch-embedding-model.mjs",
    "mint-pat": "tsx scripts/mint-pat.mjs",
    "predev": "node scripts/fetch-embedding-model.mjs",
    "dev": "concurrently -k -n vite,api -c cyan,magenta \"vite\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "cross-env PORT=8787 tsx watch server/index.ts",
    "prebuild": "node scripts/fetch-embedding-model.mjs",
    "build": "tsc -b && vite build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:graph": "node scripts/test-knowledge-graph-physics.mjs",
    "preview": "vite preview",
    "benchmark:tokens": "tsx scripts/benchmark-token-savings.mts && tsx scripts/render-token-savings.mts",
    "benchmark:output": "tsx scripts/benchmark-output-tokens.mts"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cookie": "^1.1.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "framer-motion": "^12.39.0",
    "helmet": "^8.2.0",
    "lucide-react": "^1.16.0",
    "openai": "^6.44.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "gpt-tokenizer": "^3.4.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^3.2.4"
  }
}
