{
  "name": "noto-mcp",
  "version": "0.1.0",
  "license": "MIT",
  "description": "MCP server exposing your Noto notes + shared memory to AI tools.",
  "type": "module",
  "bin": {
    "noto-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
